# ──────────────────────────────────────────────
# Astro build-time (copy to .env for local dev)
# ──────────────────────────────────────────────

# Cloudflare Turnstile site key (public — safe to expose in HTML)
# Test key below always passes challenges locally
PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# ──────────────────────────────────────────────
# Cloudflare Pages Function runtime
# (copy to .dev.vars for local dev with wrangler)
# ──────────────────────────────────────────────

# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=

# Contact form recipient
CONTACT_TO=hallo@ictira.com

# Contact form sender — must be a verified domain in Resend
CONTACT_FROM=kontakt@ictira.com

# Cloudflare Turnstile secret key — https://dash.cloudflare.com → Turnstile
# Test key below always passes challenges locally
TURNSTILE_SECRET=1x0000000000000000000000000000000AA
