---
const navLinks = [
  { href: '#leistungen', label: 'Leistungen' },
  { href: '#preise',     label: 'Preise' },
  { href: '#prozess',    label: 'Prozess' },
  { href: '#faq',        label: 'FAQ' },
  { href: '#kontakt',    label: 'Kontakt' },
];

const utilLinks = [
  { href: '/impressum', label: 'Impressum' },
  { href: '/datenschutz', label: 'Datenschutz' },
];
---
<footer class="footer">
  <div class="inner section-inner">
    <div class="top">
      <a href="#" class="logo">
        <img src="/logo-mark.svg" width="28" height="28" alt="" aria-hidden="true" />
        <span class="logo-wordmark">ictira</span>
      </a>
      <nav class="nav">
        {navLinks.map(({ href, label }) => <a href={href}>{label}</a>)}
      </nav>
    </div>
    <div class="bottom">
      <span>© ictira GmbH · 2026 · Nordwestschweiz</span>
      <div class="utils">
        {utilLinks.map(({ href, label }) => <a href={href}>{label}</a>)}
      </div>
    </div>
  </div>
</footer>

<style>
  .footer { padding: 48px 32px 32px; border-top: 1px solid var(--line); }

  .top {
    display: flex; justify-content: space-between; align-items: center;
    flex-wrap: wrap; gap: 24px; padding-bottom: 32px;
    border-bottom: 1px solid var(--line);
  }
  .logo { display: flex; align-items: center; gap: 12px; }
  .logo-wordmark { font-weight: 800; font-size: 20px; letter-spacing: -0.04em; color: var(--ink); }

  .nav { display: flex; gap: 24px; flex-wrap: wrap; }
  .nav a { color: var(--ink); font-size: 14px; }
  .nav a:hover { opacity: .6; }

  .bottom {
    margin-top: 24px; display: flex; justify-content: space-between;
    flex-wrap: wrap; gap: 12px; color: var(--mute);
    font-size: 12px; font-family: var(--mono);
    text-transform: uppercase; letter-spacing: .06em;
  }
  .utils { display: flex; gap: 16px; flex-wrap: wrap; }
  .utils a { color: var(--ink); }
  .utils a:hover { opacity: .6; }

  @media (max-width: 768px) {
    .nav { display: none; }
  }
  @media (max-width: 480px) {
    .footer { padding-left: 16px; padding-right: 16px; }
  }
</style>
