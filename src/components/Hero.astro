---
---
<section class="hero">
  <div class="hero-card">
    <div class="orb"></div>
    <div class="blob"></div>

    <div class="meta">
      <span>→ Webdesign-Studio aus dem Baselbiet</span>
    </div>

    <div class="reveal">
      <h1 class="headline">
        Deine<br />
        Website,<br />
        <span class="gradient">fertig.</span>
      </h1>
    </div>

    <div class="sub-row">
      <div class="reveal" data-delay="100">
        <p class="body-copy">
          Wir bauen schnelle, eigenständige Websites zum Fixpreis. Keine
          Agentur-Rechnung, die nach drei Monaten explodiert. Du weisst ab
          Tag eins, was du bekommst, wann du es bekommst und was es kostet.
        </p>
      </div>
      <div class="reveal btns" data-delay="200">
        <a href="#preise" class="btn-light">Pakete ansehen →</a>
        <a href="#kontakt" class="btn-ghost">Gespräch buchen</a>
      </div>
    </div>
  </div>

  <!-- Marquee 1 -->
  <div class="marquee-strip strip-1">
    <div class="marquee-wrap">
      <div class="marquee-track" id="marquee1">
        <div class="marquee-content content-1">
          <span>CHF 1490 · Onepager</span><span>✦</span>
          <span>CHF 1990 · Bis 5 Seiten</span><span>✦</span>
          <span>CHF 2990 · Grössere Sites</span><span>✦</span>
          <span>Fixpreis, garantiert</span><span>✦</span>
        </div>
        <div class="marquee-content content-1" aria-hidden="true">
          <span>CHF 1490 · Onepager</span><span>✦</span>
          <span>CHF 1990 · Bis 5 Seiten</span><span>✦</span>
          <span>CHF 2990 · Grössere Websites</span><span>✦</span>
          <span>Fixpreis, garantiert</span><span>✦</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Marquee 2 -->
  <div class="marquee-strip strip-2">
    <div class="marquee-wrap">
      <div class="marquee-track" id="marquee2">
        <div class="marquee-content content-2">
          <span>Basel</span><span>·</span><span>Aarau</span><span>·</span>
          <span>Solothurn</span><span>·</span><span>Liestal</span><span>·</span>
          <span>Olten</span><span>·</span><span>Baden</span><span>·</span>
        </div>
        <div class="marquee-content content-2" aria-hidden="true">
          <span>Basel</span><span>·</span><span>Aarau</span><span>·</span>
          <span>Solothurn</span><span>·</span><span>Liestal</span><span>·</span>
          <span>Olten</span><span>·</span><span>Baden</span><span>·</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero { padding: 96px 32px 0; }

  .hero-card {
    position: relative; padding: 72px 56px 64px;
    background: var(--ink); color: var(--paper);
    border-radius: 48px; overflow: hidden;
  }

  .orb {
    position: absolute; width: 380px; height: 380px; border-radius: 50%;
    background: radial-gradient(circle at 35% 35%, var(--accent), #0a0780 75%);
    filter: blur(2px); box-shadow: 0 0 200px #3A2BFF44;
    pointer-events: none; top: 10%; right: 5%;
    animation: orbFloat 6s ease-in-out infinite;
  }
  @keyframes orbFloat {
    0%,100% { transform: translateY(0) translateX(0); }
    33%      { transform: translateY(-20px) translateX(12px); }
    66%      { transform: translateY(10px) translateX(-8px); }
  }

  .blob {
    position: absolute; top: 58%; right: 20%;
    width: 110px; height: 110px; border-radius: 50%;
    background: var(--hot); pointer-events: none;
    animation: blobFloat 5s ease-in-out infinite;
  }
  @keyframes blobFloat {
    0%,100% { transform: translateY(0); }
    50%      { transform: translateY(-16px); }
  }

  .meta {
    display: flex; justify-content: space-between; flex-wrap: wrap; gap: 12px;
    font-family: var(--mono); font-size: 12px; opacity: .6;
    text-transform: uppercase; letter-spacing: .08em; margin-bottom: 56px;
  }

  .headline {
    font-size: clamp(80px, 14vw, 210px); line-height: 0.87;
    margin: 0; font-weight: 900; letter-spacing: -0.06em; position: relative; z-index: 2;
  }
  .gradient {
    background: linear-gradient(100deg, var(--accent), var(--hot));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text; font-style: italic; font-weight: 800;
  }

  .sub-row {
    display: grid; grid-template-columns: 1fr auto; gap: 48px;
    margin-top: 72px; align-items: end; position: relative; z-index: 2;
  }
  .body-copy {
    font-size: clamp(17px, 1.5vw, 24px); line-height: 1.35;
    margin: 0; font-weight: 500; max-width: 600px;
  }
  .btns { display: flex; gap: 12px; flex-wrap: wrap; justify-content: flex-end; }
  .btn-light {
    padding: 18px 26px; background: var(--paper); color: var(--ink);
    font-weight: 600; font-size: 16px; border-radius: 999px;
    display: inline-flex; align-items: center; gap: 10px;
  }
  .btn-ghost {
    padding: 18px 26px; background: transparent; color: var(--paper);
    border: 1.5px solid rgba(244,242,236,0.3);
    font-weight: 600; font-size: 16px; border-radius: 999px;
  }

  /* Marquees */
  .marquee-wrap { overflow: hidden; white-space: nowrap; }
  .marquee-track { display: inline-flex; will-change: transform; }

  .marquee-strip { border-radius: 8px; }
  .strip-1 {
    margin: -28px 0 0; position: relative; z-index: 2;
    transform: rotate(-2deg); background: var(--accent); color: #fff; padding: 18px 0;
  }
  .strip-2 {
    margin: -14px 0 64px;
    transform: rotate(1.2deg); background: var(--ink); color: var(--paper); padding: 14px 0;
  }

  .marquee-content { display: inline-flex; gap: 48px; padding-right: 48px; }
  .content-1 { font-size: clamp(22px, 2.5vw, 36px); font-weight: 700; letter-spacing: -0.02em; }
  .content-2 {
    font-size: 20px; font-weight: 500;
    font-family: var(--mono); text-transform: uppercase; letter-spacing: .06em;
  }

  @media (max-width: 768px) {
    .hero-card { padding: 48px 28px 40px; }
    .sub-row { grid-template-columns: 1fr; gap: 32px; }
    .btns { justify-content: flex-start; }
    .orb { width: 240px; height: 240px; }
    .blob { display: none; }
  }
  @media (max-width: 480px) {
    .hero { padding-left: 16px; padding-right: 16px; }
  }
</style>

<script>
  function setupMarquee(id: string, speed: number, reverse: boolean) {
    const track = document.getElementById(id);
    if (!track) return;
    let x = 0;
    const tick = () => {
      const w = (track.firstElementChild as HTMLElement)?.offsetWidth || 1200;
      x -= speed * (reverse ? -1 : 1);
      if (x < -w) x = 0;
      if (x > 0)  x = -w;
      track.style.transform = `translateX(${x}px)`;
      requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);
  }

  setupMarquee('marquee1', 0.8,  false);
  setupMarquee('marquee2', 0.45, true);
</script>
