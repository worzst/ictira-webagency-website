---
const packages = ['Onepager', 'Standard', 'Grösser', 'Unsicher'];
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '';
---
<section id="kontakt" class="contact">
  <div class="card section-inner">
    <div class="glow"></div>

    <!-- Left: heading + details -->
    <div class="left">
      <div class="label">→ Let's go</div>
      <div class="reveal">
        <h2 class="heading">
          Starten<br />wir was <em>Cooles?</em>
        </h2>
      </div>
      <div class="details">
        <div class="detail">
          <div class="detail-label">Email</div>
          <div class="detail-val">
            <a href="mailto:hallo@ictira.com">hallo@ictira.com</a>
          </div>
        </div>
        {/* <div class="detail">
          <div class="detail-label">Telefon</div>
          <div class="detail-val">+41 61 000 00 00</div>
        </div> */}
<div class="detail">
          <div class="detail-label">Sitz</div>
          <div class="detail-val small">ictira GmbH · 4455 Zunzgen</div>
        </div>
      </div>
    </div>

    <!-- Right: form -->
    <div class="right">
      <div id="contactSuccess" class="success">
        <div class="success-icon">✓</div>
        <h3>Danke! Wir melden uns bald.</h3>
        <p>Meist innerhalb von 24 Stunden.</p>
      </div>

      <form id="contactForm" class="form">
        <input class="hp" type="text" name="_hp" tabindex="-1" autocomplete="off" aria-hidden="true" />
        <input class="field" type="text"  name="name"    placeholder="Wie heisst du?"    required />
        <input class="field" type="email" name="email"   placeholder="Deine Email"       required />
        <input class="field" type="text"  name="firm"    placeholder="Firma (optional)"          />
        <input class="field" type="tel"   name="phone"   placeholder="Telefon (optional)"         />

        <div class="radios">
          {packages.map(pkg => (
            <label class="radio-label">
              <input type="radio" name="pack" value={pkg} />&nbsp;{pkg}
            </label>
          ))}
        </div>

        <textarea class="field textarea" name="message" placeholder="Erzähl uns kurz, was du vorhast…" rows="4"></textarea>

        <div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-theme="dark"></div>

        <button type="submit" class="submit">
          <span id="submitLabel">Anfrage abschicken</span><span>→</span>
        </button>
        <p id="contactError" class="error-msg" style="display:none">
          Etwas ist schiefgelaufen. Bitte versuche es erneut oder schreib uns direkt an <a href="mailto:hallo@ictira.com">hallo@ictira.com</a>.
        </p>
      </form>
    </div>
  </div>
</section>

<style>
  .contact { padding: 0 32px 96px; }

  .card {
    padding: 72px 56px 64px; background: var(--ink); color: var(--paper);
    border-radius: 48px; display: grid; grid-template-columns: 1.1fr 1fr;
    gap: 64px; position: relative; overflow: hidden;
  }
  .glow {
    position: absolute; bottom: -140px; left: -80px; width: 380px; height: 380px;
    border-radius: 50%; background: var(--accent); opacity: .2; filter: blur(50px); pointer-events: none;
  }

  .left, .right { position: relative; }

  .label {
    font-family: var(--mono); font-size: 12px; opacity: .6;
    text-transform: uppercase; letter-spacing: .08em; margin-bottom: 20px;
  }
  .heading {
    font-size: clamp(52px, 6vw, 100px); line-height: 0.9;
    margin: 0; font-weight: 800; letter-spacing: -0.055em;
  }
  .heading em { color: var(--accent); font-style: italic; }

  .details { margin-top: 48px; display: grid; gap: 24px; }
  .detail-label {
    font-size: 11px; opacity: .5; margin-bottom: 4px;
    font-family: var(--mono); text-transform: uppercase; letter-spacing: .08em;
  }
  .detail-val { font-size: 20px; font-weight: 500; }
  .detail-val a { color: var(--paper); }
  .detail-val.small { font-size: 15px; opacity: .7; }

  .form { display: grid; gap: 14px; }
  .field {
    padding: 18px 22px; border-radius: 999px;
    border: 1.5px solid rgba(255,255,255,0.15);
    background: rgba(255,255,255,0.05); color: var(--paper);
    outline: none; font-size: 15px; width: 100%;
  }
  .field::placeholder { color: rgba(244,242,236,0.4); }
  .textarea { border-radius: 24px; resize: none; }

  .radios { display: flex; gap: 8px; flex-wrap: wrap; }
  .radio-label {
    padding: 10px 16px; border-radius: 999px;
    border: 1.5px solid rgba(255,255,255,0.18);
    font-size: 13px; cursor: pointer; color: var(--paper);
    display: flex; align-items: center; gap: 4px;
    transition: border-color .2s, background .2s;
  }
  .radio-label:has(input:checked) {
    background: rgba(255,255,255,0.12);
    border-color: rgba(255,255,255,0.6);
  }

  .submit {
    padding: 20px 28px; border-radius: 999px; background: var(--accent); color: #fff;
    border: none; font-size: 16px; font-weight: 700; cursor: pointer;
    display: flex; justify-content: space-between; align-items: center;
  }

  .success {
    display: none; flex-direction: column; justify-content: center;
    align-items: center; height: 100%; gap: 20px; text-align: center;
  }
  .success.show { display: flex; }
  .success-icon {
    width: 64px; height: 64px; border-radius: 50%; background: var(--success);
    display: flex; align-items: center; justify-content: center;
    font-size: 28px; color: var(--ink);
  }
  .success h3 { font-size: 32px; font-weight: 700; margin: 0; letter-spacing: -0.03em; }
  .success p  { opacity: .7; margin: 0; font-size: 16px; }

  .error-msg { font-size: 13px; color: var(--hot); margin: 4px 0 0; line-height: 1.5; }
  .error-msg a { color: var(--hot); text-decoration: underline; }

  .hp { position: absolute; left: -9999px; opacity: 0; pointer-events: none; }

  @media (max-width: 1024px) {
    .card { grid-template-columns: 1fr; }
  }
  @media (max-width: 768px) {
    .card { padding: 48px 28px; gap: 40px; }
  }
  @media (max-width: 480px) {
    .contact { padding-left: 16px; padding-right: 16px; }
  }
</style>

<script>
  const form    = document.getElementById('contactForm') as HTMLFormElement;
  const success = document.getElementById('contactSuccess')!;
  const errorEl = document.getElementById('contactError') as HTMLElement;
  const label   = document.getElementById('submitLabel')!;
  const btn     = form.querySelector('.submit') as HTMLButtonElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    btn.disabled = true;
    label.textContent = 'Wird gesendet…';
    errorEl.style.display = 'none';

    const data = Object.fromEntries(new FormData(form).entries());

    try {
      const res = await fetch('/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        form.style.display = 'none';
        success.classList.add('show');
        (window as any).dataLayer?.push({ event: 'form_submit_success' });
      } else {
        throw new Error('server');
      }
    } catch {
      btn.disabled = false;
      label.textContent = 'Anfrage abschicken';
      errorEl.style.display = 'block';
    }
  });
</script>

<script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
