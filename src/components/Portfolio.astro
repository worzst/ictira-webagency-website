---
interface Props {}

const projects = [
  { name: 'Metzgerei Brunner',    category: 'Handwerk · Basel',    year: '2025', bg: 'repeating-linear-gradient(45deg,#0E0F12 0 2px,transparent 2px 14px)' },
  { name: 'Atelier Widmer',       category: 'Architektur · Aarau', year: '2025', bg: 'radial-gradient(circle at 30% 30%,#3A2BFF,#0E0F12)' },
  { name: 'Praxis Dr. Meier',     category: 'Medizin · Solothurn', year: '2024', bg: 'linear-gradient(135deg,#FF4D2E,#FFC107)' },
  { name: 'Flux Coffee Roasters', category: 'Gastro · Liestal',    year: '2024', bg: 'repeating-linear-gradient(0deg,#0E0F12 0 2px,#F4F2EC 2px 16px)' },
  { name: 'Alpin Consulting AG',  category: 'Beratung · Olten',    year: '2024', bg: 'conic-gradient(from 0deg at 50% 50%,#3A2BFF,#FF4D2E,#3A2BFF)' },
  { name: 'Verein KunstRaum',     category: 'Kultur · Baden',      year: '2023', bg: 'linear-gradient(135deg,#0E0F12,#3A2BFF)' },
];

const delays = [0, 60, 120, 80, 160, 240];
---
<section id="arbeiten" class="portfolio">
  <div class="section-inner">
    <div class="head">
      <div class="reveal">
        <h2 class="heading">Frisch<br />gelauncht.</h2>
      </div>
      <a href="#" class="all-link">Alle 24 Projekte →</a>
    </div>

    <div class="grid-3">
      {projects.map((p, i) => (
        <div class="reveal item" data-delay={String(delays[i])}>
          <div class="thumb-wrap">
            <div class="thumb" style={`background:${p.bg};`}></div>
          </div>
          <div class="meta">
            <div>
              <div class="name">{p.name}</div>
              <div class="cat">{p.category}</div>
            </div>
            <div class="year">{p.year}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .portfolio { padding: 0 32px 96px; }

  .head {
    display: flex; justify-content: space-between; align-items: flex-end;
    margin-bottom: 48px; flex-wrap: wrap; gap: 24px;
  }
  .heading {
    font-size: clamp(56px, 7vw, 96px); line-height: 0.95;
    margin: 0; font-weight: 700; letter-spacing: -0.05em; color: var(--ink);
  }
  .all-link {
    color: var(--ink); font-size: 16px; font-weight: 500;
    border-bottom: 2px solid var(--ink); padding-bottom: 4px;
  }

  .item { cursor: pointer; }
  .thumb-wrap { overflow: hidden; border-radius: 20px; height: 280px; margin-bottom: 16px; }
  .thumb { width: 100%; height: 100%; transition: transform .6s cubic-bezier(.2,.8,.2,1); }
  .item:hover .thumb { transform: scale(1.05); }

  .meta { display: flex; justify-content: space-between; align-items: flex-start; gap: 8px; }
  .name { font-size: 22px; font-weight: 600; letter-spacing: -0.02em; color: var(--ink); }
  .cat { font-size: 13px; color: var(--mute); margin-top: 4px; }
  .year { font-family: var(--mono); font-size: 12px; color: var(--mute); flex-shrink: 0; }

  @media (max-width: 768px) {
    .head { flex-direction: column; align-items: flex-start; }
  }
  @media (max-width: 480px) {
    .portfolio { padding-left: 16px; padding-right: 16px; }
  }
</style>
