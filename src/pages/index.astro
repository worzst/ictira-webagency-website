---
---
<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>ictira GmbH — Webdesign zum Fixpreis</title>
  <meta name="description" content="Schnelle, eigenständige Websites zum Fixpreis. Kein Agentur-Overhead. CHF 790 / 1490 / 2990." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter+Tight:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,500;1,700;1,800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      background: #ECEAE4;
      font-family: 'Inter Tight', system-ui, sans-serif;
      color: #0E0F12;
      overflow-x: hidden;
    }
    a { text-decoration: none; }
    ul, ol { list-style: none; padding: 0; margin: 0; }
    input, textarea, button { font-family: inherit; }

    /* ── Nav ── */
    .nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      padding: 0 32px; height: 68px;
      display: flex; align-items: center; justify-content: space-between;
      transition: background .3s, border-color .3s;
    }
    .nav.scrolled {
      background: #ECEAE4EE;
      backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(14,15,18,0.12);
    }
    .nav-logo { display: flex; align-items: center; gap: 12px; }
    .nav-logo-mark {
      width: 32px; height: 32px; border-radius: 50%;
      background: #3A2BFF; position: relative; flex-shrink: 0;
    }
    .nav-logo-mark::after {
      content: ''; position: absolute; inset: 8px;
      border-radius: 50%; background: #FF4D2E;
    }
    .nav-wordmark { font-weight: 800; font-size: 22px; letter-spacing: -0.04em; color: #0E0F12; }
    .nav-links {
      display: flex; gap: 4px; padding: 4px;
      background: #0E0F12; border-radius: 999px;
    }
    .nav-links a {
      color: #F4F2EC; padding: 8px 16px; font-size: 13px;
      font-weight: 500; border-radius: 999px;
      transition: background .2s;
    }
    .nav-links a:hover { background: rgba(244,242,236,0.12); }
    .nav-cta {
      background: #3A2BFF; color: #fff; padding: 12px 20px;
      border-radius: 999px; font-size: 13px; font-weight: 600;
      display: inline-flex; align-items: center; gap: 8px;
    }
    .nav-cta-dot { width: 8px; height: 8px; border-radius: 50%; background: #8DFE4C; flex-shrink: 0; }
    .nav-mobile-btn {
      display: none; background: none; border: none;
      cursor: pointer; padding: 8px; flex-direction: column; gap: 5px;
    }
    .nav-mobile-btn span { display: block; width: 22px; height: 2px; background: #0E0F12; }
    .nav-mobile-menu {
      display: none; position: fixed; top: 68px; left: 0; right: 0;
      background: #ECEAE4EE; backdrop-filter: blur(10px);
      padding: 16px 32px 24px; border-bottom: 1px solid rgba(14,15,18,0.12);
      flex-direction: column; gap: 4px; z-index: 99;
    }
    .nav-mobile-menu.open { display: flex; }
    .nav-mobile-menu a {
      color: #0E0F12; padding: 12px 0; font-size: 18px; font-weight: 600;
      border-bottom: 1px solid rgba(14,15,18,0.08);
    }

    /* ── Reveal ── */
    .reveal {
      opacity: 0; transform: translateY(40px);
      transition: opacity .8s ease, transform .9s cubic-bezier(.16,.8,.2,1);
    }
    .reveal.in { opacity: 1; transform: none; }
    .reveal[data-delay="60"]  { transition-delay: 60ms; }
    .reveal[data-delay="80"]  { transition-delay: 80ms; }
    .reveal[data-delay="100"] { transition-delay: 100ms; }
    .reveal[data-delay="120"] { transition-delay: 120ms; }
    .reveal[data-delay="160"] { transition-delay: 160ms; }
    .reveal[data-delay="180"] { transition-delay: 180ms; }
    .reveal[data-delay="200"] { transition-delay: 200ms; }
    .reveal[data-delay="240"] { transition-delay: 240ms; }
    .reveal[data-delay="300"] { transition-delay: 300ms; }

    /* ── Hero ── */
    .hero { padding: 96px 32px 0; }
    .hero-card {
      position: relative; padding: 72px 56px 64px;
      background: #0E0F12; color: #F4F2EC;
      border-radius: 48px; overflow: hidden;
    }
    .hero-orb {
      position: absolute; width: 380px; height: 380px; border-radius: 50%;
      background: radial-gradient(circle at 35% 35%, #3A2BFF, #0a0780 75%);
      filter: blur(2px); box-shadow: 0 0 200px #3A2BFF44;
      pointer-events: none; top: 10%; right: 5%;
      animation: orbFloat 6s ease-in-out infinite;
    }
    @keyframes orbFloat {
      0%,100% { transform: translateY(0) translateX(0); }
      33%      { transform: translateY(-20px) translateX(12px); }
      66%      { transform: translateY(10px) translateX(-8px); }
    }
    .hero-blob {
      position: absolute; top: 58%; right: 20%;
      width: 110px; height: 110px; border-radius: 50%;
      background: #FF4D2E; pointer-events: none;
      animation: blobFloat 5s ease-in-out infinite;
    }
    @keyframes blobFloat {
      0%,100% { transform: translateY(0); }
      50%      { transform: translateY(-16px); }
    }
    .hero-meta {
      display: flex; justify-content: space-between; flex-wrap: wrap; gap: 12px;
      font-family: 'JetBrains Mono', monospace; font-size: 12px; opacity: .6;
      text-transform: uppercase; letter-spacing: .08em; margin-bottom: 56px;
    }
    .hero-h1 {
      font-size: clamp(80px, 14vw, 210px); line-height: 0.87;
      margin: 0; font-weight: 900; letter-spacing: -0.06em; position: relative; z-index: 2;
    }
    .hero-h1-gradient {
      background: linear-gradient(100deg, #3A2BFF, #FF4D2E);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text; font-style: italic; font-weight: 800;
    }
    .hero-sub {
      display: grid; grid-template-columns: 1fr auto; gap: 48px;
      margin-top: 72px; align-items: end; position: relative; z-index: 2;
    }
    .hero-body { font-size: clamp(17px,1.5vw,24px); line-height: 1.35; margin: 0; font-weight: 500; max-width: 600px; }
    .hero-btns { display: flex; gap: 12px; flex-wrap: wrap; justify-content: flex-end; }
    .btn-pill-light {
      padding: 18px 26px; background: #F4F2EC; color: #0E0F12;
      font-weight: 600; font-size: 16px; border-radius: 999px;
      display: inline-flex; align-items: center; gap: 10px;
    }
    .btn-pill-ghost {
      padding: 18px 26px; background: transparent; color: #F4F2EC;
      border: 1.5px solid rgba(244,242,236,0.3);
      font-weight: 600; font-size: 16px; border-radius: 999px;
    }

    /* ── Marquee ── */
    .marquee-wrap { overflow: hidden; white-space: nowrap; }
    .marquee-track { display: inline-flex; will-change: transform; }
    .marquee-strip-1 {
      margin: -28px 0 0; position: relative; z-index: 2;
      transform: rotate(-2deg); background: #3A2BFF; color: #fff;
      padding: 18px 0; border-radius: 8px;
    }
    .marquee-strip-2 {
      margin: -14px 0 64px;
      transform: rotate(1.2deg); background: #0E0F12; color: #F4F2EC;
      padding: 14px 0; border-radius: 8px;
    }
    .marquee-inner-1 {
      display: inline-flex; gap: 48px; padding-right: 48px;
      font-size: clamp(22px,2.5vw,36px); font-weight: 700; letter-spacing: -0.02em;
    }
    .marquee-inner-2 {
      display: inline-flex; gap: 48px; padding-right: 48px; font-size: 20px;
      font-weight: 500; font-family: 'JetBrains Mono', monospace;
      text-transform: uppercase; letter-spacing: .06em;
    }

    /* ── Services ── */
    .services { padding: 96px 32px; }
    .section-inner { max-width: 1360px; margin: 0 auto; }
    .section-label {
      display: inline-flex; align-items: center; gap: 8px;
      font-family: 'JetBrains Mono', monospace; font-size: 12px;
      color: #6A6D73; text-transform: uppercase; letter-spacing: .08em; margin-bottom: 16px;
    }
    .section-label-dot { width: 8px; height: 8px; border-radius: 50%; background: #3A2BFF; flex-shrink: 0; }
    .services-head {
      display: flex; justify-content: space-between; align-items: flex-end;
      margin-bottom: 56px; flex-wrap: wrap; gap: 32px;
    }
    .services-h2 { font-size: clamp(56px,7vw,96px); line-height: 0.95; margin: 0; font-weight: 700; letter-spacing: -0.05em; color: #0E0F12; }
    .services-desc { max-width: 380px; font-size: 18px; line-height: 1.45; color: #6A6D73; margin: 0; }
    .grid-3 { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; }
    .card-service {
      padding: 32px 28px; border-radius: 28px; min-height: 280px;
      display: flex; flex-direction: column; justify-content: space-between;
      transition: transform .25s;
    }
    .card-service:hover { transform: translateY(-4px); }
    .card-service-idx { font-family: 'JetBrains Mono', monospace; font-size: 14px; opacity: .7; }
    .card-service-title { font-size: 36px; font-weight: 700; letter-spacing: -0.03em; margin-bottom: 12px; }
    .card-service-desc { font-size: 15px; line-height: 1.5; opacity: .85; }

    /* ── Pricing ── */
    .pricing { padding: 96px 32px; }
    .pricing-label {
      font-family: 'JetBrains Mono', monospace; font-size: 12px; color: #6A6D73;
      text-transform: uppercase; letter-spacing: .08em; margin-bottom: 20px;
    }
    .pricing-h2 { font-size: clamp(64px,9vw,128px); line-height: 0.9; margin: 0; font-weight: 800; letter-spacing: -0.055em; color: #0E0F12; }
    .pricing-h2 em { font-style: italic; color: #3A2BFF; }
    .pricing-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; align-items: start; }
    .card-pricing { padding: 32px 28px; border-radius: 32px; display: flex; flex-direction: column; position: relative; }
    .card-pricing-badge {
      position: absolute; top: -16px; left: 50%;
      transform: translateX(-50%) rotate(-3deg);
      background: #FF4D2E; color: #fff; padding: 8px 18px; border-radius: 999px;
      font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .05em; white-space: nowrap;
    }
    .card-pricing-head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 4px; }
    .card-pricing-name { font-size: 30px; font-weight: 700; letter-spacing: -0.03em; }
    .card-pricing-num { font-family: 'JetBrains Mono', monospace; font-size: 12px; opacity: .5; }
    .card-pricing-tag { font-size: 14px; opacity: .7; margin-bottom: 32px; }
    .card-pricing-price { display: flex; align-items: baseline; gap: 6px; margin-bottom: 6px; }
    .card-pricing-chf { font-size: 18px; opacity: .6; }
    .card-pricing-amount { font-size: 96px; font-weight: 800; letter-spacing: -0.06em; line-height: 0.9; }
    .card-pricing-suffix { font-size: 18px; opacity: .6; }
    .card-pricing-sub { font-family: 'JetBrains Mono', monospace; font-size: 12px; opacity: .5; margin-bottom: 24px; }
    .card-pricing-list { flex: 1; }
    .card-pricing-item { display: flex; gap: 10px; padding: 9px 0; font-size: 14px; align-items: flex-start; }
    .check-circle {
      width: 18px; height: 18px; border-radius: 50%; color: #fff;
      display: inline-flex; align-items: center; justify-content: center;
      font-size: 11px; flex-shrink: 0; margin-top: 1px;
    }
    .card-pricing-cta {
      margin-top: 24px; padding: 16px 20px; border-radius: 999px; color: #fff;
      font-weight: 600; font-size: 15px; display: flex; justify-content: space-between; align-items: center;
    }
    .card-pricing-delivery { margin-top: 12px; font-family: 'JetBrains Mono', monospace; font-size: 11px; opacity: .5; text-align: center; }
    .pricing-footnote { text-align: center; margin-top: 40px; font-size: 14px; color: #6A6D73; font-family: 'JetBrains Mono', monospace; }

    /* ── Process ── */
    .process { padding: 0 32px 96px; }
    .process-card {
      max-width: 1360px; margin: 0 auto; padding: 72px 56px;
      background: #3A2BFF; color: #fff; border-radius: 48px;
      position: relative; overflow: hidden;
    }
    .process-deco {
      position: absolute; top: -80px; right: -80px; width: 320px; height: 320px;
      border-radius: 50%; background: #FF4D2E; opacity: .85; pointer-events: none;
    }
    .process-label { font-family: 'JetBrains Mono', monospace; font-size: 12px; opacity: .8; text-transform: uppercase; letter-spacing: .08em; margin-bottom: 20px; }
    .process-h2 { font-size: clamp(52px,7vw,100px); line-height: 0.95; margin: 0; font-weight: 800; letter-spacing: -0.05em; max-width: 860px; }
    .process-h2 em { font-style: italic; color: #FEF08A; }
    .process-steps { margin-top: 80px; display: grid; grid-template-columns: repeat(5,1fr); gap: 20px; position: relative; }
    .process-line { position: absolute; top: 14px; left: 5%; right: 5%; height: 2px; background: rgba(255,255,255,0.25); pointer-events: none; }
    .process-step { position: relative; z-index: 2; }
    .process-step-num {
      width: 30px; height: 30px; border-radius: 50%;
      background: #fff; color: #3A2BFF;
      display: flex; align-items: center; justify-content: center;
      font-size: 12px; font-weight: 700; margin-bottom: 24px;
      font-family: 'JetBrains Mono', monospace;
    }
    .process-step-title { font-size: 26px; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 10px; }
    .process-step-desc { font-size: 14px; line-height: 1.5; opacity: .85; }

    /* ── Portfolio ── */
    .portfolio { padding: 0 32px 96px; }
    .portfolio-head { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 48px; flex-wrap: wrap; gap: 24px; }
    .portfolio-h2 { font-size: clamp(56px,7vw,96px); line-height: 0.95; margin: 0; font-weight: 700; letter-spacing: -0.05em; color: #0E0F12; }
    .portfolio-all { color: #0E0F12; font-size: 16px; font-weight: 500; border-bottom: 2px solid #0E0F12; padding-bottom: 4px; }
    .portfolio-item { cursor: pointer; }
    .portfolio-thumb-wrap { overflow: hidden; border-radius: 20px; height: 280px; margin-bottom: 16px; }
    .portfolio-thumb { width: 100%; height: 100%; transition: transform .6s cubic-bezier(.2,.8,.2,1); }
    .portfolio-item:hover .portfolio-thumb { transform: scale(1.05); }
    .portfolio-meta { display: flex; justify-content: space-between; align-items: flex-start; gap: 8px; }
    .portfolio-name { font-size: 22px; font-weight: 600; letter-spacing: -0.02em; color: #0E0F12; }
    .portfolio-cat { font-size: 13px; color: #6A6D73; margin-top: 4px; }
    .portfolio-year { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: #6A6D73; flex-shrink: 0; }

    /* ── FAQ ── */
    .faq { padding: 96px 32px; }
    .faq-inner { max-width: 1040px; margin: 0 auto; }
    .faq-label { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: #6A6D73; text-transform: uppercase; letter-spacing: .08em; margin-bottom: 20px; }
    .faq-h2 { font-size: clamp(56px,8vw,96px); line-height: 0.95; margin: 0; font-weight: 800; letter-spacing: -0.05em; color: #0E0F12; }
    .faq-h2 em { font-style: italic; color: #3A2BFF; }
    .faq-item {
      margin-bottom: 12px; padding: 24px 28px; border-radius: 24px; cursor: pointer;
      transition: background .25s, color .25s;
    }
    .faq-item.closed { background: #F4F2EC; color: #0E0F12; border: 1px solid rgba(14,15,18,0.12); }
    .faq-item.open   { background: #0E0F12; color: #F4F2EC; border: 1px solid transparent; }
    .faq-row { display: flex; justify-content: space-between; align-items: center; gap: 24px; }
    .faq-q { font-size: clamp(17px,1.4vw,22px); font-weight: 600; letter-spacing: -0.02em; }
    .faq-toggle {
      width: 36px; height: 36px; border-radius: 50%; flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      font-size: 18px; color: #fff; transition: all .25s; border: none; cursor: pointer;
    }
    .faq-item.closed .faq-toggle { background: #0E0F12; transform: rotate(0deg); }
    .faq-item.open   .faq-toggle { background: #3A2BFF; transform: rotate(45deg); }
    .faq-answer { overflow: hidden; font-size: 16px; line-height: 1.55; transition: max-height .35s, opacity .3s, margin-top .25s; }
    .faq-item.closed .faq-answer { max-height: 0; opacity: 0; margin-top: 0; }
    .faq-item.open   .faq-answer { max-height: 200px; opacity: .85; margin-top: 14px; }

    /* ── Contact ── */
    .contact { padding: 0 32px 96px; }
    .contact-card {
      max-width: 1360px; margin: 0 auto; padding: 72px 56px 64px;
      background: #0E0F12; color: #F4F2EC; border-radius: 48px;
      display: grid; grid-template-columns: 1.1fr 1fr; gap: 64px;
      position: relative; overflow: hidden;
    }
    .contact-glow {
      position: absolute; bottom: -140px; left: -80px; width: 380px; height: 380px;
      border-radius: 50%; background: #3A2BFF; opacity: .2; filter: blur(50px); pointer-events: none;
    }
    .contact-label { font-family: 'JetBrains Mono', monospace; font-size: 12px; opacity: .6; text-transform: uppercase; letter-spacing: .08em; margin-bottom: 20px; }
    .contact-h2 { font-size: clamp(52px,6vw,100px); line-height: 0.9; margin: 0; font-weight: 800; letter-spacing: -0.055em; }
    .contact-h2 em { color: #3A2BFF; font-style: italic; }
    .contact-details { margin-top: 48px; display: grid; gap: 24px; }
    .contact-detail-label { font-size: 11px; opacity: .5; margin-bottom: 4px; font-family: 'JetBrains Mono', monospace; text-transform: uppercase; letter-spacing: .08em; }
    .contact-detail-val { font-size: 20px; font-weight: 500; }
    .contact-detail-val a { color: #F4F2EC; }
    .contact-detail-val.small { font-size: 15px; opacity: .7; }
    .contact-form { display: grid; gap: 14px; position: relative; }
    .form-input, .form-textarea {
      padding: 18px 22px; border-radius: 999px;
      border: 1.5px solid rgba(255,255,255,0.15);
      background: rgba(255,255,255,0.05); color: #F4F2EC;
      outline: none; font-size: 15px; width: 100%;
    }
    .form-input::placeholder, .form-textarea::placeholder { color: rgba(244,242,236,0.4); }
    .form-textarea { border-radius: 24px; resize: none; }
    .form-radios { display: flex; gap: 8px; flex-wrap: wrap; }
    .form-radio-label {
      padding: 10px 16px; border-radius: 999px;
      border: 1.5px solid rgba(255,255,255,0.18);
      font-size: 13px; cursor: pointer; color: #F4F2EC;
      display: flex; align-items: center; gap: 8px;
    }
    .form-submit {
      padding: 20px 28px; border-radius: 999px; background: #3A2BFF; color: #fff;
      border: none; font-size: 16px; font-weight: 700; cursor: pointer;
      display: flex; justify-content: space-between; align-items: center;
    }
    .contact-success {
      display: none; flex-direction: column; justify-content: center;
      align-items: center; height: 100%; gap: 20px; text-align: center;
    }
    .contact-success.show { display: flex; }
    .contact-success-icon { width: 64px; height: 64px; border-radius: 50%; background: #8DFE4C; display: flex; align-items: center; justify-content: center; font-size: 28px; color: #0E0F12; }
    .contact-success h3 { font-size: 32px; font-weight: 700; margin: 0; letter-spacing: -0.03em; }
    .contact-success p { opacity: .7; margin: 0; font-size: 16px; }

    /* ── Footer ── */
    .footer { padding: 48px 32px 32px; border-top: 1px solid rgba(14,15,18,0.12); }
    .footer-inner { max-width: 1360px; margin: 0 auto; }
    .footer-top { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 24px; padding-bottom: 32px; border-bottom: 1px solid rgba(14,15,18,0.12); }
    .footer-logo { display: flex; align-items: center; gap: 12px; }
    .footer-logo-mark { width: 28px; height: 28px; border-radius: 50%; background: #3A2BFF; position: relative; flex-shrink: 0; }
    .footer-logo-mark::after { content: ''; position: absolute; inset: 7px; border-radius: 50%; background: #FF4D2E; }
    .footer-wordmark { font-weight: 800; font-size: 20px; letter-spacing: -0.04em; color: #0E0F12; }
    .footer-nav { display: flex; gap: 24px; flex-wrap: wrap; }
    .footer-nav a { color: #0E0F12; font-size: 14px; }
    .footer-nav a:hover { opacity: .6; }
    .footer-bottom { margin-top: 24px; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 12px; color: #6A6D73; font-size: 12px; font-family: 'JetBrains Mono', monospace; text-transform: uppercase; letter-spacing: .06em; }
    .footer-utils { display: flex; gap: 16px; flex-wrap: wrap; }
    .footer-utils a { color: #0E0F12; }
    .footer-utils a:hover { opacity: .6; }

    /* ── Responsive ── */
    @media (max-width: 1024px) {
      .grid-3 { grid-template-columns: repeat(2,1fr); }
      .pricing-grid { grid-template-columns: 1fr; max-width: 500px; margin: 0 auto; }
      .card-pricing[data-popular] { transform: none; }
      .process-steps { grid-template-columns: repeat(3,1fr); }
      .contact-card { grid-template-columns: 1fr; }
    }
    @media (max-width: 768px) {
      .hero-card { padding: 48px 28px 40px; }
      .hero-sub { grid-template-columns: 1fr; gap: 32px; }
      .hero-btns { justify-content: flex-start; }
      .hero-orb { width: 240px; height: 240px; }
      .hero-blob { display: none; }
      .grid-3 { grid-template-columns: 1fr; }
      .process-steps { grid-template-columns: 1fr 1fr; gap: 32px; }
      .process-line { display: none; }
