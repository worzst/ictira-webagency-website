<script>
  // Nav scroll state
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => {
    nav.classList.toggle('scrolled', window.scrollY > 20);
  }, { passive: true });

  // Mobile nav toggle
  const mobileBtn = document.getElementById('navMobileBtn');
  const mobileMenu = document.getElementById('navMobileMenu');
  mobileBtn.addEventListener('click', () => mobileMenu.classList.toggle('open'));
  mobileMenu.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => mobileMenu.classList.remove('open'));
  });

  // Marquee animation
  function setupMarquee(id, speed, reverse) {
    const track = document.getElementById(id);
    if (!track) return;
    let x = 0;
    const tick = () => {
      const w = track.firstElementChild?.offsetWidth || 1200;
      x -= speed * (reverse ? -1 : 1);
      if (x < -w) x = 0;
      if (x > 0) x = -w;
      track.style.transform = `translateX(${x}px)`;
      requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);
  }
  setupMarquee('marquee1', 0.8, false);
  setupMarquee('marquee2', 0.45, true);

  // Reveal on scroll
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('in'); observer.unobserve(e.target); }
    });
  }, { threshold: 0.12 });
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

  // FAQ accordion
  const faqItems = document.querySelectorAll('.faq-item');
  faqItems.forEach(item => {
    item.addEventListener('click', () => {
      const wasOpen = item.classList.contains('open');
      faqItems.forEach(i => { i.classList.remove('open'); i.classList.add('closed'); });
      if (!wasOpen) { item.classList.add('open'); item.classList.remove('closed'); }
    });
  });

  // Contact form success state
  const form = document.getElementById('contactForm');
  const success = document.getElementById('contactSuccess');
  form.addEventListener('submit', e => {
    e.preventDefault();
    form.style.display = 'none';
    success.classList.add('show');
  });
</script>

