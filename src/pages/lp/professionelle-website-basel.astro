---
import Layout from '../../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import { getImage } from 'astro:assets';
import stefanPhoto from '../../assets/picture/StefanWorzallaSquareSmall.jpg';
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '';
const stefan = await getImage({ src: stefanPhoto, width: 360, format: 'webp' });
---
<Layout
  title="Professionelle Website erstellen lassen - Fixpreis, fertig in 7 Tagen | ictira"
  description="Website erstellen lassen zum Fixpreis ab CHF 1'490. Individuelles Design, fertig in 7 Tagen. Speziell für Selbstständige und KMU in Basel, BL, AG & SO."
>

  <!-- ── Sticky LP Header ── -->
  <header class="lp-header">
    <div class="lp-header-inner">
      <a href="/" class="lp-logo" aria-label="ictira Startseite">
        <img src="/logo.svg" alt="ictira" height="28" />
      </a>
      <a href="#anfrage" class="lp-header-cta">Kostenloses Gespräch buchen →</a>
    </div>
  </header>

  <!-- ── 1. Hero / Above the fold ── -->
  <section class="hero">
    <div class="hero-inner section-inner">
      <div class="hero-left">
        <div class="hero-eyebrow">Webdesign für KMU · Basel &amp; Region</div>
        <h1 class="hero-h1">
          Professionelle Website<br />
          erstellen lassen<br />
          <em>Fixpreis, fertig<br />in 7 Tagen.</em>
        </h1>
        <p class="hero-sub">
          Ich erstelle Ihre professionelle Website zum Fixpreis ab CHF&nbsp;1'490 –
          inkl. Design, Text, Technik &amp; Hosting-Setup.
          Speziell für Selbstständige und KMU in Basel, BL, AG &amp; SO.
        </p>
        <ul class="hero-bullets">
          <li><span class="bullet-check">✓</span> Individuelles Design, keine Baukasten-Templates</li>
          <li><span class="bullet-check">✓</span> In 7 Tagen startklar – ohne Technik-Stress für Sie</li>
          <li><span class="bullet-check">✓</span> Fixpreis, keine versteckten Kosten</li>
          <li><span class="bullet-check">✓</span> 15+ Jahre IT-Erfahrung</li>
        </ul>
        <div class="hero-trust">
          <span>📍 Zunzgen BL · Fokus auf KMU in Basel, BL, AG &amp; SO</span>
        </div>
      </div>
      <div class="hero-right">
        <div class="hero-form-card" id="anfrage">
          <div class="form-heading">Kostenloses 15-Minuten-Gespräch buchen</div>
          <div class="form-sub">Unverbindlich – per Telefon oder Video.</div>

          <div id="lpSuccess" class="lp-success">
            <div class="success-icon">✓</div>
            <h3>Danke! Ich melde mich bald.</h3>
            <p>Meist innerhalb von 24 Stunden.</p>
          </div>

          <form id="lpForm" class="lp-form">
            <input class="hp" type="text" name="_hp" tabindex="-1" autocomplete="off" aria-hidden="true" />
            <input class="lp-field" type="text"  name="name"    placeholder="Ihr Name"                    required />
            <input class="lp-field" type="text"  name="firm"    placeholder="Firma (optional)"                     />
            <input class="lp-field" type="email" name="email"   placeholder="Ihre E-Mail-Adresse"          required />
            <input class="lp-field" type="tel"   name="phone"   placeholder="Ihre Telefonnummer"           required />
            <input class="lp-field" type="text"  name="message" placeholder="Wann passt es Ihnen? (optional)"      />

            <div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-theme="light"></div>

            <button type="submit" class="lp-submit">
              <span id="lpSubmitLabel">Gespräch sichern</span>
              <span>→</span>
            </button>
            <div class="form-trust">
              <span>✓ Antwort innerhalb von 24 Stunden</span>
              <span>✓ 15+ Jahre IT-Erfahrung</span>
            </div>
            <p id="lpError" class="lp-error" style="display:none">
              Etwas ist schiefgelaufen. Bitte schreib uns direkt an
              <a href="mailto:hallo@ictira.com">hallo@ictira.com</a>.
            </p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- ── 2. Für wen ── -->
  <section class="fuer-wen">
    <div class="section-inner fw-inner">
      <div class="reveal fw-label">Für wen ich Websites baue</div>
      <h2 class="reveal fw-heading" data-delay="60">
        Sie erkennen sich<br /><em>hier wieder?</em>
      </h2>
      <div class="fw-grid">
        {[
          { icon: 'tabler:browser-x',    text: 'Sie haben noch gar keine richtige Firmenwebsite, oder eine, bei der Sie sich selbst schämen, wenn Kunden danach suchen.' },
          { icon: 'tabler:refresh-alert', text: 'Ihre Website wirkt veraltet und passt nicht mehr zu Ihrem Unternehmen.' },
          { icon: 'tabler:clock-off',    text: 'Sie haben keine Zeit und keine Lust, sich mit Technik, Texten und Baukasten-Tools herumzuschlagen.' },
          { icon: 'tabler:trending-up',  text: 'Sie wollen mehr Anfragen über Google aber ohne teure Agentur und unklare Kosten.' },
        ].map((item, i) => (
          <div class="reveal fw-card" data-delay={String(i * 60)}>
            <div class="fw-icon"><Icon name={item.icon} /></div>
            <p class="fw-text">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── 3. Was ist inklusive ── -->
  <section class="inkl">
    <div class="section-inner inkl-inner">
      <div class="reveal inkl-label">Was Sie konkret bekommen</div>
      <h2 class="reveal inkl-heading" data-delay="60">
        Alles aus einer Hand –<br /><em>ohne Überraschungen.</em>
      </h2>
      <div class="inkl-cols">
        <div class="reveal inkl-col" data-delay="80">
          <div class="inkl-col-title">Was ich für Sie übernehme</div>
          <ul class="inkl-list benefit-list">
            <li><span class="inkl-check accent">✓</span> Konzept &amp; Design: Von Grund auf nach Ihrem Briefing</li>
            <li><span class="inkl-check accent">✓</span> Texte schreiben auf Basis Ihrer Informationen</li>
            <li><span class="inkl-check accent">✓</span> Technische Umsetzung, Hosting &amp; Domain-Einrichtung</li>
            <li><span class="inkl-check accent">✓</span> SEO-Grundlagen, damit Google Sie findet</li>
            <li><span class="inkl-check accent">✓</span> Revisions-Runden bis alles stimmt</li>
          </ul>
        </div>
        <div class="reveal inkl-col" data-delay="120">
          <div class="inkl-col-title">Was Sie nicht mehr machen müssen</div>
          <ul class="inkl-list feature-list">
            <li><span class="inkl-check">✓</span> Kein Baukasten-Gefrickel durch endlose Optionen</li>
            <li><span class="inkl-check">✓</span> Keine Technik-Probleme lösen (Domains, SSL, Hosting)</li>
            <li><span class="inkl-check">✓</span> Keine Texte schreiben oder selber redigieren</li>
            <li><span class="inkl-check">✓</span> Kein Hin-und-her mit mehreren Dienstleistern</li>
            <li><span class="inkl-check">✓</span> Keine bösen Überraschungen bei der Rechnung</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ── 4. Pakete & Preise ── -->
  <section class="pakete">
    <div class="section-inner">
      <div class="reveal pakete-label">Transparente Preise</div>
      <h2 class="reveal pakete-heading" data-delay="60">
        Fixpreis-Pakete –<br /><em>klar und fair.</em>
      </h2>
      <div class="pakete-grid">
        {[
          {
            name: 'Onepager',
            sub: 'Perfekt für Einzelunternehmer, Solopreneure und schnelle Launches.',
            price: '1\'490',
            time: 'Fertig in 7 Tagen',
            popular: false,
            items: [
              'Ihr Angebot auf einer Seite – klar, überzeugend, modern',
              'Individuelles Design, kein Baukasten-Template',
              'Mobile-optimiert, SSL & Basis-SEO inklusive',
              'Kontaktformular & Domain-Setup inklusive',
            ],
          },
          {
            name: 'Standard',
            sub: 'Perfekt für klassische KMU mit mehreren Leistungsbereichen.',
            price: '1\'990',
            time: 'Fertig in 7–10 Tagen',
            popular: true,
            items: [
              '5 Seiten: Start, Leistungen, Über uns, Referenzen, Kontakt',
              'Individuelles Design in Ihrem Branding',
              'Texte auf Basis Ihrer Infos – Sie schreiben nichts',
              'Mobile-optimiert, SSL, SEO pro Seite & Google Maps',
              'Domain & Hosting-Setup inklusive',
            ],
          },
          {
            name: 'Grösser',
            sub: 'Perfekt für wachsende Firmen mit komplexerem Bedarf.',
            price: '2\'990',
            time: 'Fertig in 14 Tagen',
            popular: false,
            items: [
              'Bis zu 10 Seiten mit individuellem Design-System',
              'Analytics & Tracking-Setup von Anfang an',
              'Persönliches Onboarding – Sie wissen danach, wie alles läuft',
              'Unbegrenzte Revisionen bis Go-Live',
            ],
          },
        ].map((pkg, i) => (
          <div class={`reveal pakete-card${pkg.popular ? ' popular' : ''}`} data-delay={String(i * 80)}>
            {pkg.popular && <div class="pakete-badge">Meistgewählt</div>}
            <div class="pakete-name">{pkg.name}</div>
            <div class="pakete-sub">{pkg.sub}</div>
            <div class="pakete-price">
              <span class="p-chf">CHF</span>
              <span class="p-amount">{pkg.price}</span>
              <span class="p-suffix">.–</span>
            </div>
            <div class="pakete-time">{pkg.time}</div>
            <ul class="pakete-list">
              {pkg.items.map(item => (
                <li><span class="p-check">✓</span>{item}</li>
              ))}
            </ul>
            <a href="#anfrage" class="pakete-cta">Paket anfragen <span>→</span></a>
          </div>
        ))}
      </div>
      <div class="reveal pakete-note" data-delay="100">
        Hosting CHF 9.90/Monat &amp; Domain CHF 19.90/Jahr werden separat ausgewiesen ·
        Bezahlung 50% bei Projektstart, 50% nach Launch ·
        Unsicher, welches Paket passt? Im kostenlosen Gespräch finden wir das gemeinsam heraus.
      </div>
    </div>
  </section>

  <!-- ── 5. Wie läuft die Zusammenarbeit ab ── -->
  <section class="prozess">
    <div class="prozess-card section-inner">
      <div class="reveal prozess-label">So funktioniert es</div>
      <h2 class="reveal prozess-heading" data-delay="60">
        Ihre neue Website<br /><em>in 3 Schritten.</em>
      </h2>
      <div class="prozess-steps">
        {[
          {
            n: '01',
            title: 'Kurzes Gespräch (15 Min.)',
            text: 'In 15 Minuten klären wir, was Sie brauchen. Am Ende wissen Sie genau, was Sie bekommen und was es kostet.',
          },
          {
            n: '02',
            title: 'Entwurf & Abstimmung',
            text: 'Sie sehen einen ersten Entwurf und geben Feedback. Ich erledige den Rest, bis alles stimmt. Nichts liegt bei Ihnen.',
          },
          {
            n: '03',
            title: 'Go-Live in 7 Tagen',
            text: 'Innerhalb von 7 Tagen ist Ihre Website live inkl. technischer Einrichtung auf Ihrer Domain und einer kurzen Video-Erklärung.',
          },
        ].map((step, i) => (
          <div class="reveal prozess-step" data-delay={String(i * 80)}>
            <div class="prozess-n">{step.n}</div>
            <div class="prozess-step-title">{step.title}</div>
            <p class="prozess-step-text">{step.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── 6. Referenzen — HIDDEN until real screenshots are ready ── -->
  <!-- <section class="referenzen">
    <div class="section-inner">
      <div class="reveal ref-label">Beispiele &amp; Referenzen</div>
      <h2 class="reveal ref-heading" data-delay="60">
        Websites,<br /><em>die wirken.</em>
      </h2>
      <div class="ref-grid">
        {[
          { branche: 'Metzgerei', ort: 'Liestal BL', text: 'Neue Website für eine lokale Metzgerei – Fokus auf einfache Kontaktaufnahme und klare Leistungskommunikation.' },
          { branche: 'Atelier / Handwerk', ort: 'Basel BS', text: 'Moderner Webauftritt für ein Handwerks-Atelier – Portfolio-Galerie, Kontaktformular, mobile-optimiert.' },
          { branche: 'Arztpraxis', ort: 'Aarau AG', text: 'Professionelle Praxis-Website – Online-Terminbuchung, Leistungsübersicht, SEO für lokale Suchanfragen.' },
        ].map((ref, i) => (
          <div class="reveal ref-card" data-delay={String(i * 60)}>
            <div class="ref-img-placeholder">
              <span>Screenshot folgt</span>
            </div>
            <div class="ref-meta">
              <div class="ref-branche">{ref.branche} · {ref.ort}</div>
              <p class="ref-text">{ref.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section> -->

  <!-- ── 7. Über Stefan ── -->
  <section class="ueber">
    <div class="section-inner ueber-inner">
      <div class="reveal ueber-photo">
        <img src={stefan.src} alt="Stefan Worzalla, ictira GmbH" class="stefan-photo" width="180" height="220" loading="lazy" decoding="async" />
      </div>
      <div class="ueber-content">
        <div class="reveal ueber-label">Wer hinter ictira steckt</div>
        <h2 class="reveal ueber-heading" data-delay="60">
          Hallo, ich bin<br /><em>Stefan Worzalla.</em>
        </h2>
        <div class="reveal ueber-text" data-delay="100">
          <p>
            Ich bin seit über 15 Jahren in der Informatik und habe ictira gegründet,
            um Selbstständige und KMU in der Nordwestschweiz schnell zu einer professionellen
            Website zu bringen. Und das ohne Agentur-Blabla.
          </p>
          <p>
            Direkte Zusammenarbeit, klare Preise, kein Overhead.
            Sie bekommen mehr als bei jeder Agentur für einen Bruchteil des Preises.
            Und ich bin persönlich erreichbar, nicht ein wechselndes Projektteam.
          </p>
        </div>
        <a href="#anfrage" class="reveal ueber-cta" data-delay="140">Gespräch buchen →</a>
      </div>
    </div>
  </section>

  <!-- ── 8. FAQ ── -->
  <section class="faq-lp">
    <div class="section-inner">
      <div class="reveal faq-label">Häufige Fragen</div>
      <h2 class="reveal faq-heading" data-delay="60">
        Ihre Fragen –<br /><em>meine Antworten.</em>
      </h2>
      <div class="faq-list">
        {[
          {
            q: 'Wie lange dauert das wirklich?',
            a: 'Nach Ihrer Freigabe des Angebots und Übermittlung Ihrer Inhalte (Logo, Texte, Bilder) ist Ihr OnePager in 7 Tagen live, eine Standard-Website in 7-10 Tagen. Selbstverständlich kann ich das Logo, die Texte und Bilder ebenfalls entwerfen und bereitstellen. Das ist kein Marketing-Versprechen – das ist mein Prozess.',
          },
          {
            q: 'Muss ich Texte und Bilder selbst liefern?',
            a: 'Nein. Ich schreibe die Texte auf Basis eines kurzen Fragebogens, den ich Ihnen schicke. Wenn Sie Fotos haben: super. Wenn nicht: Ich nutze hochwertige Stockbilder passend zu Ihrer Branche.',
          },
          {
            q: 'Was ist, wenn mir das Design nicht gefällt?',
            a: 'Dann arbeite ich nach. Ich liefere Revisionen bis Sie zufrieden sind. Und wenn es nach 30 Tagen wirklich nicht passt: volle Rückerstattung.',
          },
          {
            q: 'Was ist nach dem Launch mit Wartung und Updates?',
            a: 'Kleinere Textänderungen sind im ersten Monat gratis. Danach biete ich ein optionales Wartungs-Paket an, kleine Anpassungen mache ich auch später schnell und kulant.',
          },
          {
            q: 'Wie läuft die Bezahlung?',
            a: '50% bei Projektstart, 50% nach dem Go-Live. Keine Vorauszahlung des vollen Betrags.',
          },
          {
            q: 'Ich bin nicht in Basel – arbeiten Sie auch mit Kunden aus anderen Regionen?',
            a: 'Ja. Mein Fokus liegt auf der Region Basel, BL, AG & SO, aber die gesamte Zusammenarbeit läuft online. Wo Sie sitzen, spielt keine Rolle.',
          },
          {
            q: 'Was kostet das Hosting danach?',
            a: 'Hosting CHF 9.90/Monat und Domain CHF 19.90/Jahr.',
          },
        ].map((item, i) => (
          <div class="reveal faq-item" data-delay={String(Math.min(i * 40, 200))}>
            <button class="faq-q" aria-expanded="false">
              <span>{item.q}</span>
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-a" hidden>
              <p>{item.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── 9. Abschluss-CTA ── -->
  <section class="abschluss">
    <div class="abschluss-card section-inner">
      <div class="abschluss-glow"></div>
      <div class="abschluss-left">
        <div class="reveal abschluss-label">Bereit?</div>
        <h2 class="reveal abschluss-heading" data-delay="60">
          Professionelle Website<br />
          erstellen lassen<br />
          <em>Fixpreis, fertig<br />in 7 Tagen.</em>
        </h2>
        <p class="reveal abschluss-text" data-delay="100">
          Buchen Sie jetzt Ihr kostenloses 15-Minuten-Gespräch.
          Ich zeige Ihnen, wie Ihre neue Website aussehen könnte –
          und ob wir zusammenpassen.
        </p>
        <div class="reveal abschluss-details" data-delay="140">
          <div class="abschluss-detail">
            <span class="ad-label">Email</span>
            <a href="mailto:hallo@ictira.com" class="ad-val">hallo@ictira.com</a>
          </div>
          <div class="abschluss-detail">
            <span class="ad-label">Standort</span>
            <span class="ad-val">Zunzgen BL · Region Basel</span>
          </div>
          <div class="abschluss-trust">
            <span>✓ Antwort innerhalb von 24 Stunden</span>
            <span>✓ 15+ Jahre IT-Erfahrung</span>
          </div>
        </div>
      </div>
      <div class="abschluss-right" id="anfrage-bottom">
        <div class="abschluss-form-head">Kostenloses Gespräch sichern</div>
        <div class="abschluss-form-sub">Unverbindlich – per Telefon oder Video.</div>

        <div id="lpSuccess2" class="lp-success dark">
          <div class="success-icon">✓</div>
          <h3>Danke! Ich melde mich bald.</h3>
          <p>Meist innerhalb von 24 Stunden.</p>
        </div>

        <form id="lpForm2" class="lp-form dark">
          <input class="hp" type="text" name="_hp" tabindex="-1" autocomplete="off" aria-hidden="true" />
          <input class="lp-field dark" type="text"  name="name"    placeholder="Ihr Name"            required />
          <input class="lp-field dark" type="tel"   name="phone"   placeholder="Ihre Telefonnummer"   required />
          <input class="lp-field dark" type="email" name="email"   placeholder="Ihre E-Mail-Adresse"  required />
          <input class="lp-field dark" type="text"  name="firm"    placeholder="Firma (optional)"                      />
          <input class="lp-field dark" type="text"  name="message" placeholder="Wann passt es Ihnen? (optional)"           />

          <div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-theme="dark"></div>

          <button type="submit" class="lp-submit accent">
            <span id="lpSubmitLabel2">Gespräch sichern</span>
            <span>→</span>
          </button>
          <p id="lpError2" class="lp-error dark" style="display:none">
            Etwas ist schiefgelaufen. Bitte schreib uns direkt an
            <a href="mailto:hallo@ictira.com">hallo@ictira.com</a>.
          </p>
        </form>
      </div>
    </div>
  </section>

  <!-- ── LP Footer ── -->
  <footer class="lp-footer">
    <div class="section-inner lp-footer-inner">
      <a href="/" class="lp-footer-logo">
        <img src="/logo.svg" alt="ictira" height="24" />
      </a>
      <div class="lp-footer-links">
        <a href="/impressum">Impressum</a>
        <a href="/datenschutz">Datenschutz</a>
      </div>
      <div class="lp-footer-copy">© 2025 ictira GmbH · Zunzgen BL · CHE-476.809.964</div>
    </div>
  </footer>

</Layout>

<style>
  /* ── LP Header ── */
  .lp-header {
    position: sticky; top: 0; z-index: 100;
    background: rgba(236,234,228,0.9); backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--line);
  }
  .lp-header-inner {
    max-width: 1360px; margin: 0 auto;
    padding: 16px 32px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .lp-logo img { display: block; }
  .lp-header-cta {
    padding: 12px 24px; border-radius: 999px;
    background: var(--accent); color: #fff;
    font-size: 14px; font-weight: 700;
    white-space: nowrap;
  }
  @media (max-width: 600px) {
    .lp-header-inner { padding: 14px 16px; }
    .lp-header-cta { font-size: 13px; padding: 10px 16px; }
  }

  /* ── Hero ── */
  .hero {
    background: var(--ink); color: var(--paper);
    padding: 80px 32px 96px;
  }
  .hero-inner {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 64px; align-items: start;
  }
  .hero-eyebrow {
    font-family: var(--mono); font-size: 12px;
    text-transform: uppercase; letter-spacing: .08em;
    opacity: .55; margin-bottom: 24px;
  }
  .hero-h1 {
    font-size: clamp(40px, 5vw, 72px); font-weight: 800;
    line-height: 1.0; letter-spacing: -0.04em; margin: 0 0 24px;
  }
  .hero-h1 em { color: var(--accent); font-style: italic; }
  .hero-sub {
    font-size: 17px; line-height: 1.6; opacity: .8;
    margin: 0 0 32px; max-width: 480px;
  }
  .hero-bullets {
    display: grid; gap: 12px; margin: 0 0 32px;
  }
  .hero-bullets li {
    display: flex; align-items: flex-start; gap: 12px;
    font-size: 15px; line-height: 1.4;
  }
  .bullet-check {
    width: 22px; height: 22px; border-radius: 50%;
    background: var(--accent); color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; font-weight: 700; flex-shrink: 0; margin-top: 1px;
  }
  .hero-trust {
    font-family: var(--mono); font-size: 12px;
    opacity: .5; letter-spacing: .02em;
  }

  /* Hero form card */
  .hero-form-card {
    background: var(--paper); color: var(--ink);
    border-radius: 32px; padding: 40px 36px;
  }
  .form-heading {
    font-size: 20px; font-weight: 700;
    letter-spacing: -0.02em; margin-bottom: 6px;
  }
  .form-sub { font-size: 13px; color: var(--mute); margin-bottom: 24px; }
